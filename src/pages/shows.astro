---
import Layout from '../layouts/Layout.astro';
import showsImg from '../assets/images/shows.png';
---

<Layout>
	<main class="min-h-screen flex flex-col items-center px-6 pt-24 pb-16">
		<img
			src={showsImg.src}
			width={showsImg.width}
			height={showsImg.height}
			alt="Shows"
			class="w-full max-w-[11rem] md:max-w-[14rem] mb-4"
			loading="lazy"
			decoding="async"
		/>
		<p class="mt-2 text-slate-700 text-center">Seid gespannt!!</p>
	</main>
</Layout>
